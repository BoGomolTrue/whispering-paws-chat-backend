# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/whispering_paws

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# VK Pay
VK_APP_SECRET=your-vk-app-secret
VK_APP_URL=https://vk.com/app123456

# YooMoney
YOOMONEY_SECRET=your-yoomoney-secret

# Telegram
TG_BOT_TOKEN=your-telegram-bot-token
WEB_APP_URL=https://your-app.com

# AI Bots
AI_API_KEY=your-ai-api-key
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-plus
AI_BOTS=true

# Uploads
UPLOADS_DIR=./public/uploads
