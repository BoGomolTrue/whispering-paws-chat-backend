# =============================================================================
# Whispering Paws — backend environment
# Скопируй в .env и подставь свои значения.
# =============================================================================

# --- Server ------------------------------------------------------------------

# development | production (в prod — secure-cookies, без auto-sync схемы БД)
NODE_ENV=development

# HTTP + WebSocket
PORT=3000
HOST=0.0.0.0

# --- Database ----------------------------------------------------------------

DATABASE_URL=postgresql://username:password@localhost:5432/whispering_paws

# --- Auth --------------------------------------------------------------------

# Секрет JWT / httpOnly-cookie. В production — длинная случайная строка.
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# --- Payments (опционально) --------------------------------------------------

# VK Mini App: вход (/auth/vk) и VK Pay webhook
VK_APP_SECRET=your-vk-app-secret

# YooMoney: проверка sha1_hash HTTP-уведомлений
YOOMONEY_SECRET=your-yoomoney-secret

# Yandex Games: проверка подписи игрока (/api/auth/yandex)
YANDEX_SECRET=your-yandex-player-secret

# Yandex Games: проверка подписи инап-покупок (Консоль → Инап-покупки → Настройки)
# Если не задан — используется YANDEX_SECRET
YANDEX_PAYMENTS_SECRET=your-yandex-payments-secret

# Telegram Mini App: вход, Stars, refund
TG_BOT_TOKEN=your-telegram-bot-token

# --- Bots (General Room) -------------------------------------------------------

# true — включить ботов; иначе выключены
AI_BOTS=true

# Папка с .jsonl датасетами и путь к SQLite-индексу (собирается при старте)
CHAT_STYLE_DIR=./data/datasets
DATASET_INDEX_PATH=./data/datasets/.cache/retrieval.db

# Вероятность ответа бота на сообщение в комнате (0–1). Остальные BOT_* — дефолты в bot-config.ts
BOT_REPLY_CHANCE=0.08
